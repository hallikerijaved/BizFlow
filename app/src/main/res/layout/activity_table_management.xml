<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/activity_padding">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Table Management"
        android:textSize="@dimen/title_text_size"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="@dimen/margin_large" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/margin_medium">

        <EditText
            android:id="@+id/etTableName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Table Name (e.g., Table 1, VIP A)"
            android:layout_marginBottom="@dimen/margin_small" />

        <EditText
            android:id="@+id/etTableCapacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Capacity (number of seats)"
            android:inputType="number"
            android:layout_marginBottom="@dimen/margin_small" />

        <Button
            android:id="@+id/btnAddTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Table"
            android:minHeight="@dimen/button_min_height" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tables"
        android:textSize="@dimen/food_name_text_size"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/margin_small" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTables"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/margin_medium" />

</LinearLayout>