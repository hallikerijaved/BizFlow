<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/margin_small"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_medium"
        android:gravity="center"
        android:minHeight="120dp">

        <TextView
            android:id="@+id/txtTableName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Table 1"
            android:textSize="@dimen/food_name_text_size"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="@dimen/margin_small" />

        <TextView
            android:id="@+id/txtTableCapacity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Capacity: 4"
            android:textSize="@dimen/food_category_text_size"
            android:gravity="center"
            android:layout_marginBottom="@dimen/margin_small" />

        <TextView
            android:id="@+id/txtTableStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AVAILABLE"
            android:textSize="@dimen/food_category_text_size"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="4dp"
            android:background="@drawable/status_background"
            android:textColor="#333" />

    </LinearLayout>

</androidx.cardview.widget.CardView>